{
	"name": "t3-cloudflare",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"repository": {
		"url": "https://github.com/exectx/t3-cloudflare"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"check": "biome check . && tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "node scripts/cf-typegen.mjs",
		"db:check": "drizzle-kit check",
		"db:check:prod": "pnpm with-env cross-env NODE_ENV=production drizzle-kit check",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:prod": "pnpm with-env cross-env NODE_ENV=production drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:push:prod": "pnpm with-env cross-env NODE_ENV=production drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:studio:prod": "pnpm with-env cross-env NODE_ENV=production drizzle-kit studio",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"with-env": "dotenv -e .dev.vars --"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.6.5",
		"@t3-oss/env-nextjs": "^0.13.10",
		"@tanstack/react-query": "^5.69.0",
		"@trpc/client": "^11.13.4",
		"@trpc/react-query": "^11.13.4",
		"@trpc/server": "^11.13.4",
		"drizzle-orm": "^0.45.1",
		"next": "^15.2.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"server-only": "^0.0.1",
		"superjson": "^2.2.1",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@cloudflare/workers-types": "^4.20250312.0",
		"@tailwindcss/postcss": "^4.0.15",
		"@types/node": "^20.14.10",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"cross-env": "^10.0.0",
		"dotenv-cli": "^8.0.0",
		"drizzle-kit": "^0.30.5",
		"opennextjs-cloudflare": "^1.0.0",
		"postcss": "^8.5.3",
		"tailwindcss": "^4.0.15",
		"typescript": "^5.8.2",
		"wrangler": "^4.30.0"
	},
	"ct3aMetadata": {
		"initVersion": "7.40.0"
	},
	"packageManager": "pnpm@10.32.1"
}
